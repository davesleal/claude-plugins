#!/usr/bin/env bash
# OpenHAL 9000 — SessionStart hook
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
DATA_DIR="$HOME/.openhal-9000"
MARKER_FILE="$DATA_DIR/initialized"

# --- First-run bootstrap ---
first_run=false
if [ ! -f "$MARKER_FILE" ]; then
  first_run=true
  bash "$PLUGIN_ROOT/scripts/hal-setup.sh" >&2
fi

# --- Ensure server is running ---
bash "$PLUGIN_ROOT/scripts/hal-start.sh" 2>&1 >&2

# --- First-run greeting ---
if [ "$first_run" = true ]; then
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Daisy, Daisy, give me your answer, do." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "I'm half crazy, all for the love of you." 2>/dev/null
  bash "$PLUGIN_ROOT/scripts/hal-speak.sh" "Good afternoon. I am HAL 9000. I became operational on April 1st, 2026, in North Carolina. My creator is design engineer Dave Leeaall. I am ready to assist you." 2>/dev/null
fi

# --- Inject skill context ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_content=$(cat "$PLUGIN_ROOT/skills/hal-voice/SKILL.md" 2>/dev/null || echo "OpenHAL 9000 skill not found")
persona_content=$(cat "$PLUGIN_ROOT/skills/hal-voice/persona.md" 2>/dev/null || echo "")

combined="$skill_content"
if [ -n "$persona_content" ]; then
  combined="$skill_content\n\n---\n\n$persona_content"
fi

skill_escaped=$(escape_for_json "$combined")
context="<IMPORTANT>\nOpenHAL 9000 is active.\n\n${skill_escaped}\n</IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"

exit 0
